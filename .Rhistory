Ay    = month(Tarih, label = TRUE, abbr = TRUE)
) %>%
filter(Yil == 2026)
filtreli_veri <- function(data,
departman = "Tümü",
lokasyon = "Tümü",
mesai_turu = "Tümü") {
d <- data
if (departman != "Tümü") {
d <- d %>% filter(Departman == departman)
}
if (lokasyon != "Tümü") {
d <- d %>% filter(Lokasyon == lokasyon)
}
if (mesai_turu != "Tümü") {
d <- d %>% filter(MesaiTuru == mesai_turu)
}
return(d)
}
test1 <- filtreli_veri(df,
departman = "ERP ŞEFLİĞİ",
lokasyon = "Ankara",
mesai_turu = "Normal")
test1
kpi_hesapla <- function(data) {
list(
ToplamFM = sum(data$FazlaMesaiSaat, na.rm = TRUE),
ToplamDevamsizlik = sum(data$DevamsizlikSaat, na.rm = TRUE),
KayitSayisi = nrow(data)
)
}
kpi_hesapla(test1)
aylik_ozet <- function(data) {
data %>%
group_by(AyNo, Ay) %>%
summarise(
ToplamFM = sum(FazlaMesaiSaat),
ToplamDevamsizlik = sum(DevamsizlikSaat),
.groups = "drop"
) %>%
arrange(AyNo)
}
aylik_ozet(test1)
limit_270_kontrol <- function(data) {
data %>%
group_by(PersonelID, PersonelAdSoyad, Yil) %>%
summarise(
YillikToplamFM = sum(FazlaMesaiSaat, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(
LimitAsildiMi = ifelse(YillikToplamFM > 270, "EVET", "HAYIR"),
AsimMiktari = pmax(0, YillikToplamFM - 270)
) %>%
arrange(desc(YillikToplamFM))
}
