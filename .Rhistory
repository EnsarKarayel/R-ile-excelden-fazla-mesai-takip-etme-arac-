mesai_turu = "Tümü")
limit_tablosu <- limit_270_kontrol(secili)
limit_tablosu
limit_tablosu %>% filter(LimitAsildiMi == "EVET")
library(ggplot2)
library(scales)
plot_fm_devamsizlik <- function(data, baslik = "Aylık Fazla Mesai ve Devamsızlık") {
ozet <- data %>%
group_by(AyNo, Ay) %>%
summarise(
ToplamFM = sum(FazlaMesaiSaat, na.rm = TRUE),
ToplamDevamsizlik = sum(DevamsizlikSaat, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(AyNo)
ggplot(ozet, aes(x = Ay)) +
geom_col(aes(y = ToplamFM), width = 0.6) +
geom_col(aes(y = ToplamDevamsizlik), width = 0.35) +
scale_y_continuous(labels = label_number(big.mark = ".", decimal.mark = ",")) +
labs(title = baslik, x = NULL, y = "Saat") +
theme_minimal()
}
plot_mesai_turu_donut <- function(data, baslik = "Mesai Türü Dağılımı") {
tur <- data %>%
group_by(MesaiTuru) %>%
summarise(Saat = sum(FazlaMesaiSaat, na.rm = TRUE), .groups = "drop") %>%
mutate(pct = ifelse(sum(Saat) == 0, 0, Saat / sum(Saat)))
ggplot(tur, aes(x = 2, y = Saat, fill = MesaiTuru)) +
geom_col(color = "white", width = 1) +
coord_polar(theta = "y") +
xlim(0.5, 2.5) +
theme_void() +
labs(title = baslik) +
geom_text(aes(label = percent(pct, accuracy = 1)),
position = position_stack(vjust = 0.5), size = 4)
}
plot_trend_fm <- function(data, baslik = "Aylık Fazla Mesai Trend") {
ozet <- data %>%
group_by(AyNo, Ay) %>%
summarise(ToplamFM = sum(FazlaMesaiSaat, na.rm = TRUE), .groups = "drop") %>%
arrange(AyNo)
ggplot(ozet, aes(x = Ay, y = ToplamFM, group = 1)) +
geom_line() +
geom_point() +
scale_y_continuous(labels = label_number(big.mark = ".", decimal.mark = ",")) +
labs(title = baslik, x = NULL, y = "Saat") +
theme_minimal()
}
secili <- filtreli_veri(df,
departman = "Tümü",
lokasyon  = "Tümü",
mesai_turu = "Tümü")
# 270 saat kontrol tablosu
limit_270_kontrol(secili)
# Grafikler
plot_fm_devamsizlik(secili, "2026 - Tümü | FM vs Devamsızlık")
plot_mesai_turu_donut(secili, "2026 - Tümü | Mesai Türleri")
plot_trend_fm(secili, "2026 - Tümü | Trend")
