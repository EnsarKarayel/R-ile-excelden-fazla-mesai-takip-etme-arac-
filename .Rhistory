# app.R
library(shiny)
library(bslib)
library(readxl)
library(dplyr)
library(lubridate)
library(ggplot2)
library(scales)
# ---- Excel yolu (sende aynı kalsın)
path <- "C:/Users/ensar.karayel/Desktop/fazla_mesai_dashboard.xlsx"
# ---- Veri okuma fonksiyonları
oku_listeler <- function(path) {
listeler <- read_excel(path, sheet = "Listeler")
departmanlar <- listeler %>%
filter(!is.na(Departman), Departman != "") %>%
distinct(Departman) %>% arrange(Departman) %>% pull(Departman)
lokasyonlar <- listeler %>%
filter(!is.na(Lokasyon), Lokasyon != "") %>%
distinct(Lokasyon) %>% arrange(Lokasyon) %>% pull(Lokasyon)
mesai_turleri <- listeler %>%
filter(!is.na(MesaiTuru), MesaiTuru != "") %>%
distinct(MesaiTuru) %>% arrange(MesaiTuru) %>% pull(MesaiTuru)
list(
departmanlar = c("Tümü", departmanlar),
lokasyonlar  = c("Tümü", lokasyonlar),
mesai_turleri = c("Tümü", mesai_turleri)
)
}
oku_veri <- function(path) {
df_raw <- read_excel(path, sheet = "Veri")
df_raw %>%
mutate(
Tarih = as.Date(Tarih),
Yil   = year(Tarih),
AyNo  = month(Tarih),
Ay    = month(Tarih, label = TRUE, abbr = TRUE)
) %>%
filter(Yil == 2026)
}
filtreli_veri <- function(data, departman = "Tümü", lokasyon = "Tümü", mesai_turu = "Tümü") {
d <- data
if (departman != "Tümü") d <- d %>% filter(Departman == departman)
if (lokasyon  != "Tümü") d <- d %>% filter(Lokasyon == lokasyon)
if (mesai_turu != "Tümü") d <- d %>% filter(MesaiTuru == mesai_turu)
d
}
kpi_hesapla <- function(data) {
list(
toplam_fm = sum(data$FazlaMesaiSaat, na.rm = TRUE),
normal_fm = sum(data$FazlaMesaiSaat[data$MesaiTuru == "Normal"], na.rm = TRUE),
hafta_sonu = sum(data$FazlaMesaiSaat[data$MesaiTuru == "Hafta Sonu"], na.rm = TRUE),
resmi_tatil = sum(data$FazlaMesaiSaat[data$MesaiTuru == "Resmi Tatil"], na.rm = TRUE),
devamsizlik = sum(data$DevamsizlikSaat, na.rm = TRUE),
kayit = nrow(data)
)
}
limit_270_kontrol <- function(data) {
data %>%
group_by(PersonelID, PersonelAdSoyad, Yil) %>%
summarise(YillikToplamFM = sum(FazlaMesaiSaat, na.rm = TRUE), .groups = "drop") %>%
mutate(
LimitAsildiMi = ifelse(YillikToplamFM > 270, "EVET", "HAYIR"),
AsimMiktari = pmax(0, YillikToplamFM - 270)
) %>%
arrange(desc(YillikToplamFM))
}
plot_fm_devamsizlik <- function(data, baslik) {
ozet <- data %>%
group_by(AyNo, Ay) %>%
summarise(
ToplamFM = sum(FazlaMesaiSaat, na.rm = TRUE),
ToplamDevamsizlik = sum(DevamsizlikSaat, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(AyNo)
ggplot(ozet, aes(x = Ay)) +
geom_col(aes(y = ToplamFM), width = 0.6) +
geom_col(aes(y = ToplamDevamsizlik), width = 0.35) +
scale_y_continuous(labels = label_number(big.mark=".", decimal.mark=",")) +
labs(title = baslik, x = NULL, y = "Saat") +
theme_minimal()
}
plot_mesai_turu_donut <- function(data, baslik) {
tur <- data %>%
group_by(MesaiTuru) %>%
summarise(Saat = sum(FazlaMesaiSaat, na.rm = TRUE), .groups = "drop")
if (nrow(tur) == 0 || sum(tur$Saat) == 0) {
return(ggplot() + theme_void() + labs(title = baslik, subtitle = "Veri yok"))
}
tur <- tur %>% mutate(pct = Saat / sum(Saat))
ggplot(tur, aes(x = 2, y = Saat, fill = MesaiTuru)) +
geom_col(color = "white", width = 1) +
coord_polar(theta = "y") +
xlim(0.5, 2.5) +
theme_void() +
labs(title = baslik) +
geom_text(aes(label = percent(pct, accuracy = 1)),
position = position_stack(vjust = 0.5), size = 4)
}
plot_trend_fm <- function(data, baslik) {
ozet <- data %>%
group_by(AyNo, Ay) %>%
summarise(ToplamFM = sum(FazlaMesaiSaat, na.rm = TRUE), .groups = "drop") %>%
arrange(AyNo)
ggplot(ozet, aes(x = Ay, y = ToplamFM, group = 1)) +
geom_line() +
geom_point() +
scale_y_continuous(labels = label_number(big.mark=".", decimal.mark=",")) +
labs(title = baslik, x = NULL, y = "Saat") +
theme_minimal()
}
# ---- UI
ui <- page_sidebar(
title = "Fazla Mesai Dashboard (2026)",
theme = bs_theme(version = 5),
sidebar = sidebar(
actionButton("yenile", "Yenile (Excel'i Tekrar Oku)"),
hr(),
selectInput("departman", "Departman", choices = c("Tümü")),
selectInput("lokasyon", "Lokasyon", choices = c("Tümü")),
selectInput("mesai", "Mesai Türü", choices = c("Tümü"))
),
layout_columns(
value_box("Toplam FM (saat)", textOutput("kpi_toplam"), showcase = bs_icon("clock")),
value_box("Normal (saat)", textOutput("kpi_normal"), showcase = bs_icon("calendar2-week")),
value_box("Hafta Sonu (saat)", textOutput("kpi_hafta"), showcase = bs_icon("sun")),
value_box("Resmi Tatil (saat)", textOutput("kpi_resmi"), showcase = bs_icon("gift")),
value_box("Devamsızlık (saat)", textOutput("kpi_dev"), showcase = bs_icon("exclamation-triangle")),
col_widths = c(4,4,4,4,4)
),
layout_columns(
card(card_header("Aylık FM vs Devamsızlık"), plotOutput("p1", height = 320)),
card(card_header("Mesai Türü Dağılımı"), plotOutput("p2", height = 320)),
card(card_header("Aylık Trend"), plotOutput("p3", height = 320)),
col_widths = c(5,4,3)
),
card(
card_header("270 Saat Limit Kontrol (2026)"),
uiOutput("limit_uyari"),
tableOutput("limit_tablosu")
)
)
